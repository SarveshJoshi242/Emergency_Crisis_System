# JWT Auth Environment Template

# ============================================================
#  JWT Configuration
#  ============================================================
#  IMPORTANT: Generate a new JWT_SECRET for each environment!
#  Command: python -c "import secrets; print(secrets.token_hex(64))"
# ============================================================

# Secret key for signing JWTs (REQUIRED)
# Length: 128 hex characters (256 bits of entropy)
JWT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT algorithm (default: HS256)
# Options: HS256, HS384, HS512 (for single-server)
# Upgrade to RS256 if you need public-key verification
JWT_ALGORITHM=HS256

# ============================================================
#  Token Expiry Configuration
# ============================================================

# Staff access tokens: 15-30 minutes recommended
# Shorter = lower blast radius on token leak
# Longer = fewer refresh requests
ACCESS_TOKEN_EXPIRE_MINUTES_STAFF=20

# Guest access tokens: 5-15 minutes recommended  
# Guests typically have more limited API usage
ACCESS_TOKEN_EXPIRE_MINUTES_GUEST=10

# Refresh tokens: 24 hours recommended
# Stored in DB, so can be revoked at logout
REFRESH_TOKEN_EXPIRE_HOURS=24

# ============================================================
#  Database Configuration
#  ============================================================

# MongoDB connection string
MONGODB_URI=mongodb+srv://username:password@cluster0.abc123.mongodb.net/?retryWrites=true&w=majority

# Database name for this application
DB_NAME=hospitality_emergency

# ============================================================
#  Server Configuration
#  ============================================================

# FastAPI environment
ENVIRONMENT=development  # or "production"

# Upload directory for fire risk model, etc.
UPLOAD_DIR=./uploads

# ============================================================
#  Logging Configuration (Optional)
#  ============================================================

LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=./logs/app.log
