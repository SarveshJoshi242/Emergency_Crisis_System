# ─────────────────────────────────────────────
#  Guest Backend — Environment Variables
#  Copy this file to .env and fill in values.
#  Never commit the real .env file.
# ─────────────────────────────────────────────

# ── MongoDB ──────────────────────────────────
# Full MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_URI=

# Database name (shared with staff backend)
DB_NAME=emergency_db

# ── JWT Authentication ────────────────────────
# Must match the JWT_SECRET used in staff_backend
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=

JWT_ALGORITHM=HS256

# Token expiry in minutes for staff tokens (validated here too)
ACCESS_TOKEN_EXPIRE_MINUTES_STAFF=20

# Token expiry in minutes for guest tokens
ACCESS_TOKEN_EXPIRE_MINUTES_GUEST=10

# Refresh token expiry in hours
REFRESH_TOKEN_EXPIRE_HOURS=24

# ── Staff Backend Integration ─────────────────
# URL where the staff backend is running
STAFF_BACKEND_URL=http://localhost:8001

# Timeout in seconds for cross-backend requests
STAFF_BACKEND_TIMEOUT=10

# ── CORS ─────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# ── Application Settings ──────────────────────
APP_NAME=Smart Emergency Management - Guest Backend
APP_VERSION=1.0.0
DEBUG=False

# ── Pathfinding ───────────────────────────────
PATHFINDING_ALGORITHM=dijkstra

# Session timeout for guests (minutes)
SESSION_TIMEOUT_MINUTES=60
