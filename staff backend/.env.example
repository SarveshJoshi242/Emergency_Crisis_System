# ─────────────────────────────────────────────
#  Staff Backend — Environment Variables
#  Copy this file to .env and fill in values.
#  Never commit the real .env file.
# ─────────────────────────────────────────────

# ── MongoDB ──────────────────────────────────
# Full MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_URI=

# Database name (shared with guest backend)
DB_NAME=emergency_db

# ── JWT Authentication ────────────────────────
# Must match the JWT_SECRET used in guest_backend
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=

JWT_ALGORITHM=HS256

# Token expiry in minutes for staff tokens
ACCESS_TOKEN_EXPIRE_MINUTES_STAFF=20

# Token expiry in minutes for guest tokens (validated here too)
ACCESS_TOKEN_EXPIRE_MINUTES_GUEST=10

# Refresh token expiry in hours
REFRESH_TOKEN_EXPIRE_HOURS=24

# ── AI / Gemini ───────────────────────────────
# AI model to use for incident image analysis
AI_MODEL=gemini-1.5-pro

# Google Gemini API key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── CORS ─────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# ── Application Settings ──────────────────────
PORT=8001
UPLOAD_DIR=uploads
DEBUG=False

# ── Render / Production ───────────────────────
# Required on Render for module imports to work correctly
# PYTHONPATH=/opt/render/project/src
